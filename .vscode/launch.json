{
  // 调试时工作目录设为【脚本所在目录】，解决相对路径(如 ./data/xxx.csv)找不到的问题
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: 当前文件（脚本目录）",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${fileDirname}",
      "justMyCode": true
    }
  ]
}
